# .env.example — PLANTILLA DE VARIABLES DE ENTORNO
# Copia este archivo como .env y llena los valores reales
# NUNCA commitees el archivo .env con valores reales

# Supabase (API / backend)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# Telegram
TELEGRAM_BOT_TOKEN=tu-bot-token-aqui
TELEGRAM_CHAT_ID=-tu-chat-id-aqui

# Frontend (Vite — necesitan prefijo VITE_)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
